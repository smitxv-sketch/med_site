{
  "name": "medical-booking-widget",
  "version": "1.0.0",
  "description": "Headless CMS-ready medical booking widget with config-based backend",
  "private": true,
  "type": "module",
  "main": "server/index.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:legacy": "tsx server/index.ts",
    "dev:web": "npm run dev -w @med-site/web",
    "dev:bff": "npm run dev -w @med-site/bff",
    "dev:cms": "npm run develop -w @med-site/cms",
    "dev:studio": "npm run dev -w @med-site/studio",
    "dev:legacy-bridge": "npm --prefix \"modx_wp-to-strapi-migration-api\" run dev",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/index.js",
    "build:web": "npm run build -w @med-site/web",
    "build:bff": "npm run build -w @med-site/bff",
    "build:packages": "npm run build -w @med-site/contracts && npm run build -w @med-site/page-engine",
    "start": "NODE_ENV=production node dist/index.js",
    "lint": "eslint src server --ext .ts,.tsx",
    "lint:design": "node scripts/design-lint.mjs",
    "test:qms:all": "tsx test-qms-all-slots.ts",
    "smoke:platform": "node scripts/smoke-platform.mjs",
    "smoke:prod": "node scripts/smoke-platform.mjs --prod",
    "uat:focus": "node scripts/uat-focus.mjs",
    "ci:platform": "node scripts/ci-platform.mjs",
    "preflight:deploy": "node scripts/deploy-preflight.mjs",
    "preflight:docker:site": "node scripts/docker-preflight-site.mjs",
    "deploy:platform": "node scripts/deploy-platform.mjs",
    "deploy:plan": "node scripts/deploy-platform.mjs --dry-run",
    "build:cms": "npm run build -w @med-site/contracts && npm run build -w @med-site/cms",
    "build:platform": "node scripts/dedupe-react.mjs && npm run build:packages && npm run build -w @med-site/bff && npm run build -w @med-site/web",
    "build:studio": "npm run build:packages && npm run build -w @med-site/bff && npm run build -w @med-site/studio",
    "build:all": "npm run build:platform && npm run build:cms"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google/genai": "^2.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.91.3",
    "@types/react-input-mask": "^3.0.6",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.6.2",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "framer-motion": "^10.16.4",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.292.0",
    "motion": "^12.40.0",
    "mysql2": "^3.18.2",
    "openai": "^6.42.0",
    "react": "18.3.1",
    "react-day-picker": "^8.10.0",
    "react-dom": "18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.48.2",
    "react-input-mask": "^2.0.4",
    "react-router-dom": "^6.30.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "esbuild": "^0.28.0",
    "eslint": "^8.54.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.22.4",
    "typescript": "^5.3.2",
    "vite": "^5.0.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ajv": "^8.20.0",
    "react-router": "^6.30.4",
    "react-router-dom": "^6.30.4",
    "date-fns": "^2.30.0",
    "date-fns-tz": {
      "date-fns": "^2.30.0"
    }
  }
}
