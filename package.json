    "@types/react-input-mask": "^3.0.6",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "framer-motion": "^10.16.4",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.292.0",
    "motion": "^12.40.0",
    "mysql2": "^3.18.2",
