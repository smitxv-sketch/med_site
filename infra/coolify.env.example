# Секреты платформы «Источник» — ТОЛЬКО в Coolify UI, не коммитить.
# Манифест приложений: infra/platform.manifest.json

# --- site-ci (BFF + Next) ---
DATA_MODE=hybrid
STRAPI_URL=https://cms.istochnik.smitx.ru
BFF_PORT=3001
STUDIO_API_SECRET=          # один секрет на site-ci и studio-istochnik
STRAPI_API_TOKEN=           # Strapi Admin → API Tokens (Full access для publish)
WEB_REVALIDATE_URL=https://istochnik.smitx.ru/api/revalidate
REVALIDATE_SECRET=          # тот же что REVALIDATE_TOKEN в site-ci (если задан)

# --- studio-istochnik ---
BFF_PROXY_URL=https://istochnik.smitx.ru/api/studio-bff
NEXT_PUBLIC_PREVIEW_URL=https://istochnik.smitx.ru

# --- ручной деплой через scripts/deploy-platform.mjs (опционально) ---
# COOLIFY_URL=https://your-coolify.example.com
# COOLIFY_API_TOKEN=
