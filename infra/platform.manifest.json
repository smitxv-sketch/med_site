{
  "version": 1,
  "project": {
    "name": "istochnik",
    "coolifyProjectUuid": "l7i7h86pibca64e3ouqkt39z",
    "environmentUuid": "os4037dvaewugdcle599l4hu",
    "githubRepo": "smitxv-sketch/med_site",
    "branch": "main"
  },
  "domains": {
    "site": "https://istochnik.smitx.ru",
    "cms": "https://cms.istochnik.smitx.ru",
    "studio": "https://studio.istochnik.smitx.ru"
  },
  "deployOrder": ["strapi-istochnik", "site-ci", "studio-istochnik"],
  "applications": {
    "strapi-istochnik": {
      "uuid": "rxb04qg8k7ia718by5829zeh",
      "buildPack": "dockerfile",
      "dockerfile": "/apps/cms/Dockerfile",
      "port": 1337,
      "watchPaths": ["apps/cms/**", "packages/contracts/**", "package.json", "package-lock.json"]
    },
    "site-ci": {
      "uuid": "v218flpmvlr8bz62p11l4mk8",
      "buildPack": "dockerfile",
      "dockerfile": "/apps/platform/Dockerfile",
      "port": 3000,
      "watchPaths": [
        "apps/web/**",
        "apps/bff/**",
        "apps/platform/**",
        "packages/**",
        "src/**",
        "scripts/start-platform.mjs",
        "scripts/dedupe-react.mjs"
      ]
    },
    "studio-istochnik": {
      "uuid": "s76jyvhsh62jrmhbvl0pbvc7",
      "buildPack": "dockerfile",
      "dockerfile": "/apps/studio/Dockerfile",
      "port": 3003,
      "dependsOn": ["site-ci"],
      "watchPaths": ["apps/studio/**", "src/**", "packages/**", "package.json", "package-lock.json"]
    }
  },
  "runtimeEnv": {
    "site-ci": [
      { "key": "DATA_MODE", "value": "hybrid", "required": true },
      { "key": "STRAPI_URL", "value": "https://cms.istochnik.smitx.ru", "required": true },
      { "key": "BFF_PORT", "value": "3001", "required": true },
      { "key": "STUDIO_API_SECRET", "secret": true, "required": true },
      { "key": "STRAPI_API_TOKEN", "secret": true, "required": false, "note": "нужен для publish из Studio" },
      { "key": "WEB_REVALIDATE_URL", "value": "https://istochnik.smitx.ru/api/revalidate", "required": false },
      { "key": "REVALIDATE_SECRET", "secret": true, "required": false, "note": "BFF → /api/revalidate" },
      { "key": "REVALIDATE_TOKEN", "secret": true, "required": false, "note": "то же значение что REVALIDATE_SECRET (Next web)" },
      { "key": "QMS_CHEL_ADDRESS", "secret": false, "required": true, "note": "МИС Челябинск — booking" },
      { "key": "QMS_CHEL_API_KEY", "secret": true, "required": true },
      { "key": "CHEL_API_ENDPOINT", "value": "https://ci74.ru/api/rest.php", "required": true, "note": "REST врачей Челябинск (ci74.ru)" },
      { "key": "BFF_INTERNAL_URL", "value": "http://127.0.0.1:3001", "required": false }
    ],
    "studio-istochnik": [
      { "key": "NODE_ENV", "value": "production", "required": true },
      { "key": "PORT", "value": "3003", "required": true },
      { "key": "STUDIO_API_SECRET", "secret": true, "required": true, "sharedWith": "site-ci" },
      { "key": "BFF_PROXY_URL", "value": "https://istochnik.smitx.ru/api/studio-bff", "required": true },
      { "key": "NEXT_PUBLIC_PREVIEW_URL", "value": "https://istochnik.smitx.ru", "required": true }
    ],
    "strapi-istochnik": [
      { "key": "HOST", "value": "0.0.0.0", "required": true },
      { "key": "PORT", "value": "1337", "required": true },
      { "key": "NODE_ENV", "value": "production", "required": true, "note": "только runtime, не buildtime в Coolify" },
      { "key": "APP_KEYS", "secret": true, "required": true },
      { "key": "API_TOKEN_SALT", "secret": true, "required": true },
      { "key": "ADMIN_JWT_SECRET", "secret": true, "required": true },
      { "key": "TRANSFER_TOKEN_SALT", "secret": true, "required": true },
      { "key": "JWT_SECRET", "secret": true, "required": true },
      { "key": "ENCRYPTION_KEY", "secret": true, "required": true },
      { "key": "DATABASE_CLIENT", "value": "postgres", "required": true },
      { "key": "DATABASE_HOST", "value": "cwdkhczc0mty75tz3nwrmmut", "required": true },
      { "key": "DATABASE_PORT", "value": "5432", "required": true },
      { "key": "DATABASE_NAME", "value": "strapi", "required": true },
      { "key": "DATABASE_USERNAME", "value": "postgres", "required": true },
      { "key": "DATABASE_PASSWORD", "secret": true, "required": true },
      { "key": "DATABASE_SSL", "value": "false", "required": true },
      { "key": "STRAPI_PLUGIN_I18N_INIT_LOCALE_CODE", "value": "ru-RU", "required": false },
      { "key": "STRAPI_TELEMETRY_DISABLED", "value": "true", "required": false },
      { "key": "STRAPI_MCP_ENABLED", "value": "false", "required": false }
    ]
  }
}
