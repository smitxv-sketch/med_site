# =============================================================================
# Legacy prototype (Vite + Express in repo root) — npm run dev
# =============================================================================

# WordPress API Endpoint (for fetching doctors and meta)
WP_API_ENDPOINT=https://ci74.ru/api/rest.php

# QMS API Credentials
QMS_CHEL_ADDRESS=
QMS_CHEL_API_KEY=
QMS_SPB_ADDRESS=
QMS_SPB_API_KEY=

# AI SDK Keys
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# reCAPTCHA (server-side verification)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# Redis (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# apps/web — see apps/web/.env.example
# apps/bff — see apps/bff/.env.example
# apps/cms — see apps/cms/.env.example
# php_backend — copy php_backend/config_access.example.php → config_access.php
# =============================================================================
