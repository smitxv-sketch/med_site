{
  "kind": "collectionType",
  "collectionName": "doctors",
  "info": {
    "singularName": "doctor",
    "pluralName": "doctors",
    "displayName": "Doctor",
    "description": "Врачи клиники (SSOT для сайта)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "fullName": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "fullName",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "misId": {
      "type": "string",
      "required": true
    },
    "legacyId": {
      "type": "string",
      "required": true
    },
    "legacySource": {
      "type": "enumeration",
      "enum": ["chel", "spb"],
      "default": "chel",
      "required": true
    },
    "specialty": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "specialties": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::specialty.specialty",
      "inversedBy": "doctors"
    },
    "branches": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::branch.branch",
      "inversedBy": "doctors"
    },
    "photoUrl": {
      "type": "string"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "experienceYears": {
      "type": "integer"
    },
    "degree": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "category": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "position": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "zvanie": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "regalia": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "activities": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "bio": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "education": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "extraEducation": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "conferences": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seoTitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seoDescription": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "phone": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "allowBooking": {
      "type": "boolean",
      "default": true
    },
    "isAdultDoctor": {
      "type": "boolean",
      "default": true
    },
    "isChildDoctor": {
      "type": "boolean",
      "default": false
    },
    "contentLocked": {
      "type": "boolean",
      "default": false
    }
  }
}
