{
  "kind": "collectionType",
  "collectionName": "design_presets",
  "info": {
    "singularName": "design-preset",
    "pluralName": "design-presets",
    "displayName": "DesignPreset",
    "description": "Пресеты Command Center (системные и пользовательские)"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "emoji": {
      "type": "string",
      "default": "🎨"
    },
    "description": {
      "type": "text"
    },
    "engineState": {
      "type": "json",
      "required": true
    },
    "pageBlocks": {
      "type": "json"
    },
    "tenant": {
      "type": "enumeration",
      "enum": ["chel", "spb", "all"],
      "default": "all",
      "required": true
    },
    "isSystem": {
      "type": "boolean",
      "default": false
    }
  }
}
