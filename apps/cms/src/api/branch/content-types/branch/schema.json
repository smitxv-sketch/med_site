{
  "kind": "collectionType",
  "collectionName": "branches",
  "info": {
    "singularName": "branch",
    "pluralName": "branches",
    "displayName": "Branch",
    "description": "Филиалы клиники (ЧЛБ: clinics, СПб: один тех. филиал)"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "city": {
      "type": "enumeration",
      "enum": ["chel", "spb"],
      "required": true
    },
    "legacyId": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "text"
    },
    "doctors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::doctor.doctor",
      "mappedBy": "branches"
    }
  }
}
