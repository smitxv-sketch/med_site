# Server
HOST=0.0.0.0
PORT=1337

# MCP для AI-агентов (Cursor). Эндпоинт: http://localhost:1337/mcp
# В production на публичном домене лучше false, если MCP не нужен снаружи
STRAPI_MCP_ENABLED=true

# Generate locally: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# Postgres (docker compose in apps/cms)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# i18n locales = city tenants (configure in admin after first run; Wave 1+)
STRAPI_PLUGIN_I18N_INIT_LOCALE_CODE=ru-RU
