{
  "mcpServers": {
    "legacy-bridge": {
      "command": "npm",
      "args": ["run", "mcp"],
      "cwd": "modx_wp-to-strapi-migration-api"
    },
    "strapi-mcp": {
      "type": "streamable-http",
      "url": "http://localhost:1337/mcp",
      "headers": {
        "Authorization": "Bearer PASTE_YOUR_STRAPI_ADMIN_TOKEN_HERE"
      }
    },
    "strapi-docs": {
      "url": "https://strapi-docs.mcp.kapa.ai"
    }
  }
}
