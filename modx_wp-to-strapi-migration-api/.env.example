# This project is both an API (Express) and a UI (Vite).
# Put real values into `.env` (do not commit). This file is only an example.

# Server
PORT="3010"
HOST="0.0.0.0"

# SPB (MODX) MySQL
SPB_DB_HOST=""
SPB_DB_PORT="3306"
SPB_DB_USER=""
SPB_DB_PASSWORD=""
SPB_DB_NAME=""
SPB_DB_PREFIX="modx_"

# Basic Auth (обязательно в production / Coolify)
SITE_USER="admin"
SITE_PASSWORD=""

# Только для локальной разработки: разрешить localhost без пароля
LEGACY_BRIDGE_ALLOW_LOCAL_NO_AUTH="true"

# CHEL (WordPress) MySQL
CHEL_DB_HOST=""
CHEL_DB_PORT="3306"
CHEL_DB_USER=""
CHEL_DB_PASSWORD=""
CHEL_DB_NAME=""

# CHEL (WordPress) Doctors REST endpoint (optional)
# If it already includes query params, `action=get_doctors` will be appended with "&".
WP_API_ENDPOINT="https://ci74.ru/api/rest.php"

# Aliases (supported for convenience in hosted envs like Coolify)
WP_DB_HOST=""
WP_DB_PORT="3306"
WP_DB_USER=""
WP_DB_PASSWORD=""
WP_DB_NAME=""
WP_DB_PREFIX="wp_"

# Firebase (client config; exposed to the browser by design)
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Back-compat (deprecated): old SPB names used in some setups
DB_HOST=""
DB_PORT="3306"
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_PREFIX="modx_"
