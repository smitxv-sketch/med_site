# This project is both an API (Express) and a UI (Vite).
# Put real values into `.env` (do not commit). This file is only an example.

# Server (локально слушаем только localhost — не открывать в LAN без reverse proxy + TLS)
PORT="3010"
HOST="127.0.0.1"

# Postgres для служебного состояния bridge (sync_map, export schema) — отдельная БД, не Strapi
BRIDGE_PG_HOST=""
BRIDGE_PG_PORT="5432"
BRIDGE_PG_DATABASE="legacy_bridge"
BRIDGE_PG_USER="postgres"
BRIDGE_PG_PASSWORD=""
# Альтернатива отдельным переменным:
# BRIDGE_DATABASE_URL="postgres://user:pass@host:5432/legacy_bridge"

# SPB (MODX) MySQL
SPB_DB_HOST=""
SPB_DB_PORT="3306"
SPB_DB_USER=""
SPB_DB_PASSWORD=""
SPB_DB_NAME=""
SPB_DB_PREFIX="modx_"

# Защита legacy MySQL (Beget / MODX) — тайминги с запасом
LEGACY_DB_QUERY_DELAY_MS="450"
LEGACY_DB_MAX_LIMIT="25"
LEGACY_DB_DEFAULT_LIMIT="20"
LEGACY_CLIENT_DELAY_MS="700"
LEGACY_HTTP_RATE_LIMIT="35"
LEGACY_HTTP_RATE_WINDOW_MS="60000"

# Bearer-токен для ИИ / MCP / скриптов (обязательно для безопасного доступа)
BRIDGE_API_TOKEN=""
BRIDGE_BASE_URL="https://bridge.istochnik.smitx.ru"

# Basic Auth (браузер / UI)
SITE_USER="admin"
SITE_PASSWORD=""

# Только dev без секретов: localhost без пароля (не включать, если задан BRIDGE_API_TOKEN)
LEGACY_BRIDGE_ALLOW_LOCAL_NO_AUTH="false"

# CHEL (WordPress) MySQL
CHEL_DB_HOST=""
CHEL_DB_PORT="3306"
CHEL_DB_USER=""
CHEL_DB_PASSWORD=""
CHEL_DB_NAME=""

# CHEL (WordPress) Doctors REST endpoint (optional)
# If it already includes query params, `action=get_doctors` will be appended with "&".
WP_API_ENDPOINT="https://ci74.ru/api/rest.php"

# Aliases (supported for convenience in hosted envs like Coolify)
WP_DB_HOST=""
WP_DB_PORT="3306"
WP_DB_USER=""
WP_DB_PASSWORD=""
WP_DB_NAME=""
WP_DB_PREFIX="wp_"

# Firebase (client config; exposed to the browser by design)
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Back-compat (deprecated): old SPB names used in some setups
DB_HOST=""
DB_PORT="3306"
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_PREFIX="modx_"
